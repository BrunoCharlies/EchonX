# EchonX — copy to `.env.local` and fill values. Never commit secrets.

# Auth.js / NextAuth v5 — https://authjs.dev/getting-started/deployment
# Generate: npm run auth:secret
AUTH_SECRET=
# Public site URL (pathname must be `/` so NextAuth keeps basePath `/api/auth`)
AUTH_URL=http://localhost:3000

# X (Twitter) OAuth 2.0 + PKCE — in the X Developer Portal set callback URL to:
#   http://localhost:3000/api/auth/callback/twitter
# Confidential "Web App" clients: set TWITTER_CLIENT_ID / TWITTER_CLIENT_SECRET (Auth.js uses
# default OAuth2 client_secret_basic against https://api.x.com/2/oauth2/token). Alternate: AUTH_TWITTER_ID / AUTH_TWITTER_SECRET.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Supabase — supports either NEXT_PUBLIC_* or plain names
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — supports either NEXT_PUBLIC_* or plain names
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_POPULAR=
STRIPE_PRICE_PRO=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://echonx.app

# Image moderation (Sightengine, Hive, AWS Rekognition, etc.)
MODERATION_PROVIDER=sightengine
MODERATION_API_USER=
MODERATION_API_SECRET=

# Admin dashboard allowlist (comma-separated X numeric user ids)
ECHONX_ADMIN_X_USER_IDS=

# --- Vercel (Production) — set in: Project → Settings → Environment Variables (Production) ---
# Do NOT commit real secrets. Callback in X Developer Portal must include:
#   https://echonx.app/api/auth/callback/twitter
# AUTH_URL=https://echonx.app
# NEXT_PUBLIC_APP_URL=https://echonx.app
# NEXT_PUBLIC_SITE_URL=https://echonx.app
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# AUTH_SECRET=   (generate with: npm run auth:secret)
# Plus Supabase / Stripe / moderation keys as above.
