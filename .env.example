# EchonX — copy to `.env.local` and fill values. Never commit secrets.



# Supabase Auth + DB — supports either NEXT_PUBLIC_* or plain names

NEXT_PUBLIC_SUPABASE_URL=

NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=

SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=



# Site origin for Supabase email redirects (password reset, etc.). Dev default port: 3002

NEXT_PUBLIC_APP_URL=http://localhost:3002



# Stripe — supports either NEXT_PUBLIC_* or plain names

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

STRIPE_PUBLISHABLE_KEY=

STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=

STRIPE_PRICE_STARTER=

STRIPE_PRICE_POPULAR=

STRIPE_PRICE_PRO=

# Library Premium (separate Stripe products / checkout per tier)
STRIPE_PRICE_LIBRARY_STARTER=
STRIPE_PRICE_LIBRARY_POPULAR=
STRIPE_PRICE_LIBRARY_PRO=

# EchonX AI Analysis ($19/mo — server only, never expose to client)
OPENAI_API_KEY=
STRIPE_PRICE_AI_ANALYSIS=



# App

NEXT_PUBLIC_SITE_URL=https://echonx.app

# Public support inbox (privacy, billing). Shown on /support and Privacy.
NEXT_PUBLIC_SUPPORT_EMAIL=support@echonx.app

# Official channel ingest (POST with Authorization: Bearer <secret>)
#   /api/cron/curator-ingest  — News RSS
#   /api/cron/qubic-x-ingest  — Qubic X mirror (@_Qubic_)

CRON_SECRET=

# Global X listening sync (cron): listeners considered online within this window (minutes). Default 30.
X_SYNC_ONLINE_WINDOW_MINUTES=30

# Official News channel: set to "false" to use only on-demand card images (zero RSS hotlink).
# CURATOR_RSS_IMAGE_HOTLINK=false



# Image moderation (Sightengine, Hive, AWS Rekognition, etc.)

MODERATION_PROVIDER=sightengine

MODERATION_API_USER=

MODERATION_API_SECRET=

# Set to "true" to block uploads when Sightengine keys are missing (edge function may still run).
# MODERATION_REQUIRE_SIGHTENGINE=true



# Admin dashboard allowlist (comma-separated X numeric user ids — legacy external profiles)

ECHONX_ADMIN_X_USER_IDS=



# Admin allowlist for email accounts (comma-separated emails, case-insensitive)

ECHONX_ADMIN_EMAILS=



# X API v2 bearer token (required to import and sync posts from @profiles)

X_BEARER_TOKEN=



# Fish Audio — TTS (S2 Pro). Admin lab: /admin/lab/voice · Production: paid plans + Library Premium (separate).

FISH_AUDIO_API_KEY=

# Optional: s2-pro (default) or s1

FISH_AUDIO_MODEL=s2-pro

# Optional preset voices from Fish library (reference_id per language)

FISH_AUDIO_REFERENCE_ID_EN=

FISH_AUDIO_REFERENCE_ID_PT_BR=

FISH_AUDIO_REFERENCE_ID_ES=

FISH_AUDIO_REFERENCE_ID_FR=



# --- Vercel (Production) — set in: Project → Settings → Environment Variables (Production) ---

# NEXT_PUBLIC_APP_URL=https://echonx.app

# NEXT_PUBLIC_SITE_URL=https://echonx.app

# Add Supabase redirect URLs in Dashboard → Authentication → URL Configuration:

#   Site URL: https://echonx.app

#   Redirect URLs: https://echonx.app/auth/callback


